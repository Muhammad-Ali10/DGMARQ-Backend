# ===== Server =====
NODE_ENV=development
PORT=5000
BASE_URL=http://localhost:5000
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# ===== Database =====
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net
DB_Name=DG-Marq
# REDIS_URL=redis://:password@localhost:6379

# ===== Authentication =====
ACCESS_TOKEN_SECRET=your-64-char-access-secret-here
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_SECRET=your-64-char-refresh-secret-here
REFRESH_TOKEN_EXPIRY=10d
SESSION_SECRET=your-128-char-session-secret-here
COOKIE_SECRET=your-128-char-cookie-secret-here

# ===== PayPal =====
PAYPAL_ENV=sandbox
PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_WEBHOOK_ID=your-webhook-id
PAYPAL_SUBSCRIPTION_PLAN_ID=P-xxxxx
SUBSCRIPTION_PRICE=9.99

# ===== Email (SendGrid SMTP) =====
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=SG.your-sendgrid-api-key
EMAIL_FROM=support@dgmarq.com
EMAIL_FROM_NAME=DGMarq

# ===== Cloudinary =====
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ===== OAuth =====
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# ===== Security =====
ENCRYPTION_KEY=your-base64-encoded-32-byte-key

# ===== Rate Limiting =====
RATE_LIMIT_MAX=500
RATE_LIMIT_WINDOW_MS=900000

# ===== Logging =====
# LOG_TO_FILE=true  # Enable file logging in development
